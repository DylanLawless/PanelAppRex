\@writefile{lot}{\contentsline {table}{\numberline {S1}{\ignorespaces \textbf  {Summary of case study queries and PanelAppRex results.} {\color {blue}\uwave {We recommend automated command-line use that accounts for all query results. For manual interface users, subjective decisions are naturally expected. We therefore measured }}``{\color {red}\sout {Subjective }}{\color {blue}\uwave {subjective }}best panels'' {\color {red}\sout {are }}{\color {blue}\uwave {as }}those reasonably preferable to the clinical query and unlikely to be excluded by users. In the benchmark scenario, broad or less relevant panels (e.g. ``COVID-19 research'') might be deprioritised in favour of more clinically aligned options such as ``Fetal anomalies'', or ``Paediatric disorders''. {\color {red}\sout {Summarised }}{\color {blue}\uwave {The results are summarised }}in \textbf  {Figure \ref {fig:performance}}. *Case study 5 had five individual cases and patient information was significantly longer than other studies. Therefore, we used OpenAI model o3-mini to converted {\color {red}\sout {it }}{\color {blue}\uwave {each }}to a standardised keyword query automatically, thereby removing our subjective bias and aligning with the other queries.}}{13}{table.1}\protected@file@percent }
\newlabel{tab:benchmark}{{S1}{13}{\textbf {Summary of case study queries and PanelAppRex results.} \DIFaddbeginFL \DIFaddFL {We recommend automated command-line use that accounts for all query results. For manual interface users, subjective decisions are naturally expected. We therefore measured }\DIFaddendFL ``\DIFdelbeginFL \DIFdelFL {Subjective }\DIFdelendFL \DIFaddbeginFL \DIFaddFL {subjective }\DIFaddendFL best panels'' \DIFdelbeginFL \DIFdelFL {are }\DIFdelendFL \DIFaddbeginFL \DIFaddFL {as }\DIFaddendFL those reasonably preferable to the clinical query and unlikely to be excluded by users. In the benchmark scenario, broad or less relevant panels (e.g. ``COVID-19 research'') might be deprioritised in favour of more clinically aligned options such as ``Fetal anomalies'', or ``Paediatric disorders''. \DIFdelbeginFL \DIFdelFL {Summarised }\DIFdelendFL \DIFaddbeginFL \DIFaddFL {The results are summarised }\DIFaddendFL in \textbf {Figure \ref {fig:performance}}. *Case study 5 had five individual cases and patient information was significantly longer than other studies. Therefore, we used OpenAI model o3-mini to converted \DIFdelbeginFL \DIFdelFL {it }\DIFdelendFL \DIFaddbeginFL \DIFaddFL {each }\DIFaddendFL to a standardised keyword query automatically, thereby removing our subjective bias and aligning with the other queries}{table.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S1}{\ignorespaces \textbf  {{\color {red}\sout {Validation and recovery of core annotation fields in the PanelAppRex dataset.}}} \textbf  {{\color {blue}\uwave {Validation of completeness major annotation fields in the core dataset.}}} (A) {\color {red}\sout {Unique genes and }}{\color {blue}\uwave {Entry-level completeness of }}HGNC {\color {red}\sout {IDs }}{\color {blue}\uwave {identifiers }}before and after {\color {red}\sout {retrieving missing HGNC entries via }}{\color {blue}\uwave {recovery using }}Ensembl {\color {red}\sout {. (B) Availability }}{\color {blue}\uwave {biomaRt with HGNC symbol input, shown together with the total number }}of {\color {red}\sout {publication annotations for }}{\color {blue}\uwave {unique }}genes {\color {blue}\uwave {in the dataset as a reference}}. ({\color {red}\sout {C}}{\color {blue}\uwave {B}}) {\color {red}\sout {Unique genes and }}{\color {blue}\uwave {Entry-level completeness of }}Ensembl gene {\color {red}\sout {IDs }}{\color {blue}\uwave {identifiers }}before and after {\color {red}\sout {biomart-based }}recovery {\color {red}\sout {of missing }}{\color {blue}\uwave {using }}Ensembl {\color {red}\sout {IDs}}{\color {blue}\uwave {biomaRt with HGNC symbol input, shown together with the total number of unique genes in the dataset as a reference}}. ({\color {blue}\uwave {C) Entry-level completeness of publication annotations, shown as the number of gene-panel entries compared to those with at least one linked publication. (}}D) {\color {red}\sout {Gene }}{\color {blue}\uwave {Entry-level completeness of disease panel annotations, shown as the number of gene-panel }}entries with {\color {red}\sout {associated }}{\color {blue}\uwave {a gene and the number with a }}disease panel {\color {red}\sout {names}}{\color {blue}\uwave {name}}. (E) {\color {red}\sout {Gene }}{\color {blue}\uwave {Entry-level completeness of mode of inheritance annotations, shown as the number of gene-panel }}entries with {\color {red}\sout {annotated }}{\color {blue}\uwave {a gene and the number with a recorded mode of inheritance}}. (F) {\color {red}\sout {Gene entries linked to an }}{\color {blue}\uwave {Entry-level completeness of }}OMIM gene {\color {red}\sout {ID. Each bar shows }}{\color {blue}\uwave {identifier annotations, shown as }}the {\color {red}\sout {count }}{\color {blue}\uwave {number }}of {\color {blue}\uwave {gene-panel }}entries with {\color {red}\sout {non-missing values for }}{\color {blue}\uwave {a gene and }}the {\color {red}\sout {respective field}}{\color {blue}\uwave {number with an OMIM gene identifier}}. {\color {red}\sout {Updated fields (HGNC }}{\color {blue}\uwave {For all panels the percentages are calculated relative to total gene-panel entries, except for panels A }}and {\color {red}\sout {Ensembl ID) reflect values recovered via external lookup using HGNC symbols. Percentage shows }}{\color {blue}\uwave {B where }}the {\color {red}\sout {complete recovery }}{\color {blue}\uwave {additional ``unique genes'' bars are calculated relative to the total number }}of {\color {red}\sout {coverage across features}}{\color {blue}\uwave {unique genes}}. }}{14}{figure.1}\protected@file@percent }
